:root,
:root[data-theme="light"] {
  color-scheme: light;
  --bg: #eef3f8;
  --panel: #ffffff;
  --panel-strong: #f6f9fd;
  --text: #061f3d;
  --muted: #607083;
  --line: #d7e2ee;
  --accent: #0057b8;
  --accent-strong: #003f8f;
  --amber: #f4b000;
  --danger: #d71920;
  --button: #e30613;
  --button-text: #ffffff;
  --shadow: 0 8px 22px rgba(13, 49, 91, 0.08);
}

:root[data-theme="dark"] {
  color-scheme: light;
  --bg: #e7eef7;
  --panel: #ffffff;
  --panel-strong: #f4f8fd;
  --text: #061f3d;
  --muted: #5c6f84;
  --line: #cfdae8;
  --accent: #004fa3;
  --accent-strong: #002f69;
  --amber: #e1a100;
  --danger: #c9141b;
  --button: #d71920;
  --button-text: #ffffff;
  --shadow: 0 8px 22px rgba(13, 49, 91, 0.1);
}

* {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  min-height: 100%;
  background: var(--bg);
  color: var(--text);
  font-family:
    Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

button,
input {
  font: inherit;
}

button {
  cursor: pointer;
}

button:disabled {
  cursor: not-allowed;
  opacity: 0.55;
}

.app-shell {
  width: min(1440px, 100%);
  margin: 0 auto;
  padding: 24px;
}

.topbar,
.status-strip,
.panel,
.modal-backdrop .auth-modal {
  border: 1px solid var(--line);
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
  padding: 18px;
  background:
    linear-gradient(135deg, color-mix(in srgb, var(--accent) 10%, transparent), transparent 54%),
    linear-gradient(180deg, color-mix(in srgb, white 3%, transparent), transparent),
    var(--panel);
  border-radius: 8px;
  box-shadow: var(--shadow);
}

.brand-lockup,
.topbar-actions,
.panel-header,
.match-actions,
.sub-row,
.email-form {
  display: flex;
  align-items: center;
  gap: 12px;
}

.brand-mark {
  position: relative;
  display: grid;
  place-items: center;
  width: 58px;
  height: 58px;
  border-radius: 8px;
  background:
    linear-gradient(145deg, color-mix(in srgb, var(--accent) 88%, white), var(--accent-strong));
  color: #07110c;
  font-weight: 900;
  box-shadow: 0 10px 30px color-mix(in srgb, var(--accent) 22%, transparent);
  overflow: hidden;
}

.brand-logo {
  width: 46px;
  height: 46px;
}

.brand-logo-ball {
  fill: #07110c;
}

.brand-logo-trail {
  fill: none;
  stroke: #07110c;
  stroke-width: 5;
  stroke-linecap: round;
  opacity: 0.72;
}

.brand-logo-trail.short {
  stroke-width: 3.5;
  opacity: 0.45;
}

.brand-logo-seam {
  fill: none;
  stroke: var(--accent);
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.brand-mark > span {
  position: absolute;
  right: 5px;
  bottom: 4px;
  font-size: 0.72rem;
  letter-spacing: 0;
}

.eyebrow {
  margin: 0 0 5px;
  color: var(--accent);
  font-size: 0.76rem;
  font-weight: 800;
  letter-spacing: 0;
  text-transform: uppercase;
}

h1,
h2,
p {
  margin-top: 0;
}

h1 {
  margin-bottom: 0;
  font-size: clamp(1.25rem, 3vw, 2rem);
  line-height: 1.05;
}

h2 {
  margin-bottom: 10px;
  font-size: 1.5rem;
  line-height: 1.12;
}

p {
  color: var(--muted);
  line-height: 1.55;
}

.icon-button,
.profile-pill,
.primary-button,
.secondary-button,
.formation-button,
.choice-card,
.player-card,
.segmented button,
.sub-row button {
  border: 1px solid var(--line);
  border-radius: 8px;
}

.icon-button,
.primary-button,
.secondary-button,
.formation-button,
.choice-card {
  transition: transform 120ms ease, box-shadow 120ms ease, border-color 120ms ease, background 120ms ease;
}

.icon-button:hover:not(:disabled),
.primary-button:hover:not(:disabled),
.secondary-button:hover:not(:disabled),
.formation-button:hover:not(:disabled),
.choice-card:hover:not(:disabled) {
  transform: translateY(-1px);
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.18);
}

.icon-button:active:not(:disabled),
.primary-button:active:not(:disabled),
.secondary-button:active:not(:disabled),
.formation-button:active:not(:disabled),
.choice-card:active:not(:disabled) {
  transform: translateY(0);
  box-shadow: none;
}

.icon-button {
  display: grid;
  place-items: center;
  width: 42px;
  height: 42px;
  background: var(--panel-strong);
  color: var(--text);
}

.icon-button:hover:not(:disabled) {
  border-color: var(--accent);
  color: var(--accent);
}

.profile-pill,
.primary-button,
.secondary-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 42px;
  padding: 0 16px;
  font-weight: 800;
}

.profile-pill,
.secondary-button {
  background: var(--panel-strong);
  color: var(--text);
}

.secondary-button:hover:not(:disabled) {
  border-color: var(--accent);
}

.primary-button {
  background: var(--button);
  color: var(--button-text);
  border-color: transparent;
}

.primary-button:hover:not(:disabled) {
  box-shadow: 0 6px 20px color-mix(in srgb, var(--accent) 35%, transparent);
}

.wide {
  width: 100%;
}

.status-strip {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1px;
  overflow: hidden;
  margin: 18px 0;
  border-radius: 8px;
  background: var(--line);
}

.status-strip div {
  padding: 14px 16px;
  background: var(--panel);
}

.status-strip span,
.table-head,
.draw-ticket span,
.muted,
.fine-print,
.hidden-stats,
.scoreboard span {
  color: var(--muted);
}

.status-strip strong {
  display: block;
  margin-top: 4px;
}

.layout-grid,
.draft-layout,
.league-layout {
  display: grid;
  gap: 18px;
}

.layout-grid {
  grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr) minmax(340px, 0.9fr);
}

.draft-layout,
.league-layout {
  grid-template-columns: minmax(0, 1.2fr) minmax(340px, 0.8fr);
}

.panel {
  position: relative;
  padding: 18px;
  background: var(--panel);
  border-radius: 8px;
  box-shadow: var(--shadow);
}

.panel::before {
  content: "";
  position: absolute;
  inset: 0 0 auto 0;
  height: 3px;
  border-radius: 8px 8px 0 0;
  background: linear-gradient(90deg, var(--accent), var(--accent-strong), transparent);
  opacity: 0.7;
}

.intro-panel {
  min-height: 360px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.mode-grid,
.formation-grid,
.candidate-grid {
  display: grid;
  gap: 10px;
}

.mode-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin: 18px 0;
}

.progression-panel,
.score-change-card {
  margin: 18px 0;
  padding: 14px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--panel-strong);
}

.progression-panel.unlocked,
.score-change-card.unlocked {
  border-color: var(--accent);
  background: color-mix(in srgb, var(--accent) 16%, var(--panel-strong));
}

.progression-head,
.progression-meta,
.score-change-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.progression-head strong,
.score-change-card strong {
  display: block;
  font-size: 1.55rem;
  line-height: 1;
}

.progress-track {
  overflow: hidden;
  height: 8px;
  margin: 14px 0 10px;
  border-radius: 999px;
  background: var(--line);
}

.progress-track span {
  display: block;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, var(--accent), var(--accent-strong));
}

.progression-meta,
.score-change-card span {
  color: var(--muted);
  font-size: 0.82rem;
  font-weight: 800;
}

.progression-panel p,
.score-change-card p {
  margin: 10px 0 0;
}

.score-change-card {
  flex-wrap: wrap;
}

.score-change-card p {
  flex-basis: 100%;
}

.choice-card,
.player-card {
  padding: 14px;
  background: var(--panel-strong);
  color: var(--text);
  text-align: left;
}

.choice-card span,
.choice-card small,
.player-card span,
.player-card small {
  display: block;
}

.choice-card.active,
.formation-button.active,
.segmented .active {
  border-color: var(--accent);
  background: color-mix(in srgb, var(--accent) 18%, var(--panel-strong));
}

.formation-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.formation-button,
.segmented button,
.sub-row button {
  min-height: 40px;
  background: var(--panel-strong);
  color: var(--text);
  font-weight: 800;
}

.sub-row .assistant-pick {
  border-color: var(--accent);
  background: color-mix(in srgb, var(--accent) 14%, var(--panel-strong));
}

.formation-button {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 8px 16px;
  text-align: left;
}

.formation-button span {
  flex: 1;
}

.formation-glyph {
  flex: none;
  width: 26px;
  height: 44px;
}

.formation-glyph-pitch {
  fill: color-mix(in srgb, var(--accent) 8%, transparent);
  stroke: var(--line);
  stroke-width: 2;
}

.formation-glyph-stroke {
  stroke: var(--line);
  stroke-width: 1.6;
  fill: none;
}

.formation-glyph-dot {
  fill: var(--accent);
  transition: fill 120ms ease;
}

.formation-button.active .formation-glyph-dot {
  fill: var(--accent-strong);
}

.draft-board {
  min-height: 680px;
}

.panel-header {
  justify-content: space-between;
  margin-bottom: 16px;
}

.spin-result {
  display: grid;
  gap: 14px;
}

.draft-spin-controls {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8px;
  flex-wrap: wrap;
}

.spin-bank {
  display: inline-flex;
  align-items: center;
  min-height: 34px;
  padding: 0 10px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: color-mix(in srgb, var(--accent-strong) 8%, var(--panel-strong));
  color: var(--accent-strong);
  font-size: 0.78rem;
  font-weight: 900;
}

.locked-button {
  opacity: 0.68;
}

.fit-explainer {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
  margin: -4px 0 14px;
  padding: 10px 12px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: color-mix(in srgb, var(--accent-strong) 6%, var(--panel-strong));
  color: var(--muted);
  font-size: 0.82rem;
  font-weight: 700;
}

.fit-explainer svg,
.fit-explainer strong {
  color: var(--accent);
}

.draw-ticket {
  display: grid;
  grid-template-columns: auto 1fr auto 1fr;
  gap: 8px 12px;
  align-items: center;
  padding: 14px;
  background: var(--panel-strong);
  border: 1px dashed var(--accent);
  border-radius: 8px;
}

.draw-ticket strong {
  font-size: 1.55rem;
}

.draw-ticket small {
  grid-column: 1 / -1;
  color: var(--amber);
}

.candidate-grid {
  grid-template-columns: repeat(auto-fill, minmax(168px, 1fr));
  gap: 8px;
}

.slot-picker-overlay {
  position: fixed;
  inset: 0;
  z-index: 60;
  display: grid;
  place-items: center;
  padding: 18px;
  background: rgba(3, 8, 6, 0.66);
  backdrop-filter: blur(2px);
  animation: cardIn 0.14s ease-out both;
}

.slot-picker {
  display: flex;
  flex-direction: column;
  gap: 14px;
  width: min(520px, 100%);
  max-height: 85vh;
  overflow-y: auto;
  padding: 18px;
  border: 1px solid var(--accent);
  border-radius: 12px;
  background: color-mix(in srgb, var(--accent) 10%, var(--panel-strong));
  box-shadow: 0 24px 60px rgba(0, 0, 0, 0.5);
}

.slot-picker strong {
  display: block;
  font-size: 1.05rem;
}

.slot-picker-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.slot-picker-positions {
  color: var(--muted);
  font-size: 0.8rem;
  font-weight: 700;
}

.slot-picker-close {
  display: grid;
  place-items: center;
  width: 30px;
  height: 30px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--panel);
  color: var(--text);
  font-size: 1.3rem;
  line-height: 1;
  cursor: pointer;
}

.slot-picker-close:hover {
  border-color: var(--accent);
}

.slot-option-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8px;
}

.slot-option {
  min-height: 62px;
  padding: 8px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--panel);
  color: var(--text);
  text-align: left;
}

.slot-option:hover {
  border-color: var(--accent);
}

.slot-option.perfect { border-color: color-mix(in srgb, var(--accent) 62%, var(--line)); }
.slot-option.good { border-color: color-mix(in srgb, var(--amber) 58%, var(--line)); }
.slot-option.okay { border-color: var(--line); }

.slot-option span,
.slot-option small {
  display: block;
  color: var(--muted);
  font-size: 0.72rem;
  font-weight: 800;
}

.slot-option strong {
  font-size: 0.88rem;
}

.player-card {
  display: flex;
  flex-direction: column;
  gap: 5px;
  transition:
    transform 140ms ease,
    border-color 140ms ease;
}

.player-card:hover {
  transform: translateY(-2px);
  border-color: var(--accent);
}

/* ── FM-style player item card ───────────────────────────────── */

.fm-card {
  position: relative;
  padding-top: 12px;
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--accent-strong) 12%, var(--panel-strong)) 0%, var(--panel-strong) 40%);
  overflow: hidden;
}

.fm-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--accent), var(--accent-strong));
}

.fm-card.good::before { background: linear-gradient(90deg, var(--amber), var(--accent-strong)); }
.fm-card.okay::before { background: var(--muted); }

.fm-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6px;
}

.card-pos {
  padding: 2px 8px;
  border-radius: 5px;
  font-size: 0.72rem;
  font-weight: 900;
  letter-spacing: 0.04em;
  color: var(--accent);
  background: color-mix(in srgb, var(--accent) 18%, transparent);
}

.card-ovr {
  display: grid;
  place-items: center;
  min-width: 38px;
  height: 38px;
  padding: 0 6px;
  border-radius: 8px;
  background: var(--accent);
  color: #06110b;
  font-size: 1.2rem;
  font-weight: 900;
}

.card-ovr.hidden {
  background: var(--panel);
  color: var(--muted);
  border: 1px dashed var(--line);
}

.card-positions {
  color: var(--muted);
  font-size: 0.82rem;
  font-weight: 700;
}

.player-shirt {
  position: relative;
  display: grid;
  place-items: center;
  width: 40px;
  height: 40px;
  color: var(--accent);
  filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.35));
}

.player-shirt svg {
  width: 32px;
  height: 32px;
}

.player-shirt span {
  position: absolute;
  top: 49%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #07110c;
  font-size: 0.72rem;
  font-weight: 950;
}

.role-targets {
  min-height: 18px;
  color: var(--accent-strong);
  font-size: 0.76rem;
  font-weight: 900;
}

.boost-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  width: fit-content;
  max-width: 100%;
  padding: 3px 7px;
  border-radius: 6px;
  background: color-mix(in srgb, var(--amber) 20%, transparent);
  color: var(--amber);
  font-size: 0.72rem;
  font-weight: 900;
}

.boost-badge.inactive {
  color: var(--muted);
  background: color-mix(in srgb, var(--muted) 16%, transparent);
}

.stat-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 4px;
  margin-top: 6px;
  font-size: 0.72rem;
}

.stat-row span {
  padding: 3px 5px;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 5px;
}

.hidden-stats {
  margin-top: 12px;
  padding: 8px;
  border: 1px dashed var(--line);
  border-radius: 8px;
}

.pick-button {
  width: 100%;
  margin-top: auto;
  min-height: 34px;
  font-size: 0.86rem;
}

.empty-state {
  display: grid;
  place-items: center;
  min-height: 380px;
  text-align: center;
  color: var(--muted);
}

.empty-state-card {
  display: grid;
  place-items: center;
  gap: 14px;
  padding: 36px 28px;
  border: 1px dashed var(--line);
  border-radius: 12px;
  background: linear-gradient(180deg, color-mix(in srgb, var(--accent) 7%, transparent), transparent);
}

.empty-state-icon {
  display: grid;
  place-items: center;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: color-mix(in srgb, var(--accent) 14%, transparent);
  color: var(--accent);
  animation: emptyIconFloat 2.6s ease-in-out infinite;
}

.empty-state-card p {
  max-width: 220px;
}

@keyframes emptyIconFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}

.squad-list {
  display: grid;
  gap: 8px;
}

.squad-row,
.injury-row {
  display: grid;
  grid-template-columns: 64px 1fr auto;
  gap: 10px;
  align-items: center;
  min-height: 44px;
  padding: 9px 10px;
  background: var(--panel-strong);
  border-radius: 8px;
}

.squad-row span {
  color: var(--accent);
  font-weight: 900;
}

.squad-row small {
  color: var(--muted);
}

.squad-row.bench span {
  color: var(--amber);
}

.rating-chip {
  display: grid;
  place-items: center;
  width: 52px;
  height: 52px;
  border-radius: 8px;
  background: var(--accent);
  color: #06110b;
}

.boost-cap {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: 10px;
  padding: 7px 9px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--panel-strong);
  color: var(--amber);
  font-size: 0.78rem;
  font-weight: 900;
}

.progression-level-chip {
  flex: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 72px;
  min-height: 34px;
  padding: 0 10px;
  border-radius: 8px;
  background: var(--accent);
  color: #06110b;
  font-size: 0.82rem;
  font-weight: 900;
}

.side-stack {
  display: grid;
  gap: 18px;
  align-content: start;
}

.timer {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 8px 11px;
  background: var(--panel-strong);
  border-radius: 8px;
  font-weight: 900;
}

.scoreboard {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
  gap: 14px;
  align-items: center;
  margin-bottom: 16px;
  padding: 16px;
  background: var(--panel-strong);
  border-radius: 8px;
}

.scoreboard > div:last-child {
  text-align: right;
}

.scoreboard span,
.scoreboard strong {
  display: block;
}

.scoreboard strong {
  min-width: 0;
  overflow-wrap: anywhere;
}

.score {
  min-width: 92px;
  text-align: center;
  color: var(--amber);
  font-size: 2rem;
  font-weight: 900;
}

.commentary-log {
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-height: 120px;
  max-height: 380px;
  overflow: auto;
  padding: 12px;
  background: #0b0d0c;
  border: 1px solid var(--line);
  border-radius: 8px;
}

:root[data-theme="light"] .commentary-log {
  background: #f0efe6;
}

.commentary-line {
  display: grid;
  grid-template-columns: 42px 1fr;
  gap: 10px;
  padding: 9px;
  background: var(--panel);
  border-radius: 8px;
}

.commentary-line span {
  color: var(--accent);
  font-weight: 900;
}

.commentary-line p {
  margin: 0;
  color: var(--text);
}

.injury-prompt {
  margin-top: 12px;
  padding: 13px;
  border: 1px solid var(--danger);
  border-radius: 8px;
  background: color-mix(in srgb, var(--danger) 12%, var(--panel));
}

.sub-row {
  flex-wrap: wrap;
}

.sub-option {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 10px;
  background: var(--panel-strong);
  font-size: 0.78rem;
  font-weight: 700;
}

.sub-option-num {
  display: grid;
  place-items: center;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: var(--amber);
  color: #1a1200;
  font-size: 0.62rem;
  font-weight: 900;
}

.sub-option-pos {
  padding: 2px 5px;
  border-radius: 4px;
  font-size: 0.62rem;
  font-weight: 900;
  letter-spacing: 0.03em;
  color: var(--accent);
  background: color-mix(in srgb, var(--accent) 16%, transparent);
}

.match-actions {
  justify-content: flex-end;
  margin-top: 14px;
}

.table {
  display: grid;
  gap: 6px;
}

.table-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 52px 52px 52px;
  gap: 8px;
  align-items: center;
  min-height: 40px;
  padding: 8px 10px;
  background: var(--panel-strong);
  border-radius: 8px;
}

.table-row strong {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.table-head {
  background: transparent;
  font-size: 0.78rem;
  font-weight: 900;
  text-transform: uppercase;
}

.segmented {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6px;
  margin-bottom: 12px;
}

.speed-controls {
  display: inline-grid;
  grid-template-columns: repeat(3, 42px);
  gap: 6px;
}

.speed-controls button {
  min-height: 42px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--panel-strong);
  color: var(--text);
  font-weight: 900;
}

.speed-controls button.active {
  border-color: var(--accent);
  background: color-mix(in srgb, var(--accent) 18%, var(--panel-strong));
}

.injury-panel {
  min-height: 180px;
}

.injury-row {
  grid-template-columns: 1fr 1fr;
  margin-top: 8px;
}

.modal-backdrop {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: grid;
  place-items: center;
  padding: 18px;
  background: rgba(0, 0, 0, 0.62);
}

.auth-modal {
  width: min(480px, 100%);
  padding: 18px;
  background: var(--panel);
  border-radius: 8px;
  box-shadow: var(--shadow);
}

.email-form {
  align-items: stretch;
  margin-top: 12px;
}

.email-form input {
  min-width: 0;
  flex: 1;
  min-height: 42px;
  padding: 0 12px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--panel-strong);
  color: var(--text);
}

.manager-pick {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin: 14px 0;
  padding: 14px;
  border: 1px solid var(--line);
  border-radius: 10px;
  background: color-mix(in srgb, var(--accent) 7%, var(--panel));
}

.manager-pick-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.manager-pick-head .eyebrow {
  margin: 0;
}

.manager-pick-rating {
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--accent);
  line-height: 1;
}

.manager-pick-name {
  font-size: 1.15rem;
  font-weight: 800;
}

.manager-pick-club {
  font-size: 0.9rem;
  opacity: 0.8;
}

.manager-pick-prompt {
  margin: 2px 0 8px;
  font-size: 0.9rem;
  opacity: 0.85;
}

.manager-pick .wide {
  margin-top: 6px;
}

.manager-wheel {
  position: relative;
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: minmax(96px, 1fr);
  gap: 8px;
  overflow: hidden;
  min-height: 54px;
  padding: 8px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--panel-strong);
}

.manager-wheel::after {
  content: "";
  position: absolute;
  inset: 6px 50% 6px auto;
  width: 2px;
  background: var(--accent);
  box-shadow: 0 0 18px color-mix(in srgb, var(--accent) 80%, transparent);
}

.manager-wheel span {
  display: grid;
  place-items: center;
  min-height: 38px;
  border-radius: 7px;
  background: var(--panel);
  color: var(--text);
  font-size: 0.8rem;
  font-weight: 900;
  animation: managerWheel 0.42s linear infinite;
}

@keyframes managerWheel {
  0% { transform: translateX(120%); }
  100% { transform: translateX(-120%); }
}

.auth-stack {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 12px;
}

.auth-stack input {
  min-height: 42px;
  padding: 0 12px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--panel-strong);
  color: var(--text);
}

.auth-divider {
  margin: 14px 0 6px;
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  opacity: 0.6;
}

.fine-print {
  margin-top: 10px;
  font-size: 0.84rem;
}

.auth-message {
  margin: 10px 0 0;
  color: var(--amber);
  font-weight: 800;
}

/* ── Language switcher ──────────────────────────────────────── */

.lang-switcher {
  display: flex;
  gap: 4px;
}

.lang-btn {
  padding: 4px 8px;
  border-radius: 6px;
  font-size: 0.72rem;
  font-weight: 900;
  letter-spacing: 0.04em;
  color: var(--muted);
  text-decoration: none;
  border: 1px solid transparent;
  transition: color 120ms, border-color 120ms;
}

.lang-btn:hover {
  color: var(--text);
  border-color: var(--line);
}

.lang-btn.active {
  color: var(--accent);
  border-color: var(--accent);
  background: color-mix(in srgb, var(--accent) 12%, transparent);
}

/* ── Spin animation ─────────────────────────────────────────── */

@keyframes spinDrum {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes revealTicket {
  0% { opacity: 0; transform: translateY(18px) scale(0.95); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes cardIn {
  0% { opacity: 0; transform: translateY(12px); }
  100% { opacity: 1; transform: translateY(0); }
}

@keyframes goalFlash {
  0%, 100% { background: var(--panel-strong); }
  30% { background: color-mix(in srgb, var(--amber) 32%, var(--panel-strong)); }
}

@keyframes redFlash {
  0%, 100% { background: var(--panel-strong); }
  30% { background: color-mix(in srgb, var(--danger) 28%, var(--panel-strong)); }
}

/* Bright two-colour flash for a goal, settling on the persistent highlighted box. */
@keyframes goalLineFlash {
  0%   { background: color-mix(in srgb, var(--amber) 60%, var(--panel-strong)); box-shadow: 0 0 0 2px var(--amber), 0 0 24px color-mix(in srgb, var(--amber) 55%, transparent); }
  25%  { background: color-mix(in srgb, var(--accent) 65%, var(--panel-strong)); box-shadow: 0 0 0 2px var(--accent), 0 0 24px color-mix(in srgb, var(--accent) 55%, transparent); }
  50%  { background: color-mix(in srgb, var(--amber) 60%, var(--panel-strong)); box-shadow: 0 0 0 2px var(--amber), 0 0 24px color-mix(in srgb, var(--amber) 55%, transparent); }
  75%  { background: color-mix(in srgb, var(--accent) 65%, var(--panel-strong)); box-shadow: 0 0 0 2px var(--accent), 0 0 24px color-mix(in srgb, var(--accent) 55%, transparent); }
  100% { background: color-mix(in srgb, var(--accent) 24%, var(--panel-strong)); box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent) 45%, transparent); }
}

@keyframes goalIconPop {
  0%   { transform: scale(0.4) rotate(-25deg); opacity: 0; }
  55%  { transform: scale(1.25) rotate(8deg); opacity: 1; }
  100% { transform: scale(1) rotate(0deg); opacity: 1; }
}

.spin-icon {
  animation: spinDrum 0.55s linear infinite;
}

.draw-ticket {
  animation: revealTicket 0.22s ease-out forwards;
}

.player-card:nth-child(1) { animation: cardIn 0.18s ease-out 0.00s both; }
.player-card:nth-child(2) { animation: cardIn 0.18s ease-out 0.07s both; }
.player-card:nth-child(3) { animation: cardIn 0.18s ease-out 0.14s both; }
.player-card:nth-child(4) { animation: cardIn 0.18s ease-out 0.21s both; }
.player-card:nth-child(5) { animation: cardIn 0.18s ease-out 0.28s both; }
.player-card:nth-child(6) { animation: cardIn 0.18s ease-out 0.35s both; }
.player-card:nth-child(7) { animation: cardIn 0.18s ease-out 0.42s both; }
.player-card:nth-child(8) { animation: cardIn 0.18s ease-out 0.49s both; }

.commentary-line.goal-flash {
  background: color-mix(in srgb, var(--accent) 24%, var(--panel-strong));
  box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent) 45%, transparent);
  animation: goalLineFlash 1.4s ease-out;
}

.commentary-line.goal-flash span {
  color: var(--amber);
}

.commentary-line.goal-flash p {
  display: flex;
  align-items: center;
  gap: 7px;
  color: #ffffff;
  font-weight: 800;
}

.goal-icon {
  flex-shrink: 0;
  color: var(--amber);
  transform-origin: center;
  animation: goalIconPop 0.5s ease-out;
}

.commentary-line.red-flash {
  animation: redFlash 0.5s ease-out;
}

/* ── OVR rating bar ─────────────────────────────────────────── */

.ovr-bar-wrap {
  margin-top: 8px;
  height: 4px;
  background: var(--line);
  border-radius: 4px;
  overflow: hidden;
}

.ovr-bar-fill {
  height: 100%;
  border-radius: 4px;
  background: linear-gradient(90deg, var(--accent), var(--accent-strong));
  transition: width 0.3s ease;
}

/* ── Position-fit badge ─────────────────────────────────────── */

.fit-badge {
  display: inline-block;
  margin-top: 6px;
  padding: 2px 7px;
  border-radius: 4px;
  font-size: 0.72rem;
  font-weight: 900;
  letter-spacing: 0.03em;
}

.fit-badge.perfect { background: color-mix(in srgb, var(--accent) 22%, transparent); color: var(--accent); }
.fit-badge.good    { background: color-mix(in srgb, var(--amber) 22%, transparent); color: var(--amber); }
.fit-badge.okay    { background: color-mix(in srgb, var(--muted) 22%, transparent); color: var(--muted); }

/* ── Team-year chip on player card ──────────────────────────── */

.team-chip {
  display: inline-block;
  margin-top: 4px;
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 0.7rem;
  font-weight: 900;
  background: var(--panel);
  border: 1px solid var(--line);
  color: var(--muted);
}

/* ── Round summary modal ─────────────────────────────────────── */

.round-summary-modal {
  max-width: 480px;
}

.summary-row {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 10px;
  align-items: center;
  padding: 10px 12px;
  background: var(--panel-strong);
  border-radius: 8px;
  margin-bottom: 6px;
}

.summary-row > span:last-child {
  text-align: right;
}

.summary-score {
  text-align: center;
  color: var(--amber);
  font-size: 1.2rem;
}

.you-label {
  color: var(--accent);
  font-weight: 900;
}

/* ── Formation pitch ─────────────────────────────────────────── */

.pitch-container {
  position: relative;
  width: 100%;
  aspect-ratio: 2 / 3;
  background: linear-gradient(180deg, #1a4d2e 0%, #1e5c36 50%, #1a4d2e 100%);
  border-radius: 8px;
  overflow: hidden;
}

.pitch-markings {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.pitch-player {
  position: absolute;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  cursor: default;
}

.pitch-dot {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--accent);
  border: 2px solid rgba(255,255,255,0.5);
  display: grid;
  place-items: center;
  font-size: 0.65rem;
  font-weight: 900;
  color: #06110b;
  box-shadow: 0 2px 6px rgba(0,0,0,0.4);
}

.pitch-dot.bench {
  background: var(--amber);
  color: #1a1200;
}

.pitch-dot.injured {
  background: var(--danger);
  color: #fff;
}

.pitch-dot.suspended {
  background: #ff4500;
  color: #fff;
}

.pitch-name {
  font-size: 0.6rem;
  font-weight: 700;
  color: rgba(255,255,255,0.85);
  text-shadow: 0 1px 3px rgba(0,0,0,0.8);
  white-space: nowrap;
  max-width: 56px;
  overflow: hidden;
  text-overflow: ellipsis;
  text-align: center;
}

.bench-row {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-top: 10px;
}

.bench-player {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 4px 8px;
  background: var(--panel-strong);
  border-radius: 6px;
  font-size: 0.72rem;
}

/* ── Pre-match panel ─────────────────────────────────────────── */

.prematch-panel {
  display: grid;
  gap: 12px;
  padding: 14px;
  background: var(--panel-strong);
  border-radius: 8px;
  margin-bottom: 14px;
}

.prematch-header {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 10px;
  align-items: center;
  text-align: center;
}

.prematch-vs {
  font-size: 1.4rem;
  font-weight: 900;
  color: var(--muted);
}

.prematch-team {
  font-size: 0.82rem;
}

.prematch-team strong {
  display: block;
  font-size: 1rem;
}

.prematch-stats {
  display: flex;
  gap: 10px;
  justify-content: center;
  flex-wrap: wrap;
}

.prematch-stat {
  padding: 4px 10px;
  background: var(--panel);
  border-radius: 6px;
  font-size: 0.75rem;
}

.prematch-stat span {
  color: var(--muted);
}

.season-pregame {
  gap: 14px;
}

.season-event-card {
  padding: 12px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--panel);
}

.season-event-card.active {
  border-color: var(--accent);
  background: color-mix(in srgb, var(--accent) 14%, var(--panel));
}

.season-event-card.danger {
  border-color: var(--danger);
  background: color-mix(in srgb, var(--danger) 12%, var(--panel));
}

.season-event-card strong,
.season-result-row strong {
  display: block;
}

.season-event-card p {
  margin: 4px 0 0;
}

.inline-actions {
  justify-content: flex-start;
  margin-top: 10px;
}

.season-results {
  margin-top: 18px;
  padding-top: 14px;
  border-top: 1px dashed var(--line);
}

.compact-header {
  margin-bottom: 10px;
}

.compact-header h2 {
  margin-bottom: 0;
  font-size: 1.1rem;
}

.season-result-row {
  display: grid;
  grid-template-columns: 34px 70px minmax(0, 1fr);
  gap: 10px;
  align-items: center;
  padding: 9px 10px;
  background: var(--panel-strong);
  border: 1px solid transparent;
  border-radius: 8px;
}

.season-result-row span {
  display: grid;
  place-items: center;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  color: #06110b;
  font-size: 0.78rem;
  font-weight: 950;
}

.season-result-row.outcome-w span {
  background: var(--accent);
}

.season-result-row.outcome-d span {
  background: var(--amber);
}

.season-result-row.outcome-l {
  border-color: var(--danger);
}

.season-result-row.outcome-l span {
  background: var(--danger);
  color: #fff;
}

.season-result-row small {
  min-width: 0;
  overflow: hidden;
  color: var(--muted);
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.season-stat-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
  margin: 12px 0;
}

.season-stat-grid div {
  padding: 10px;
  border-radius: 8px;
  background: var(--panel-strong);
}

.season-stat-grid span {
  display: block;
  color: var(--muted);
  font-size: 0.72rem;
  font-weight: 900;
  text-transform: uppercase;
}

.season-stat-grid strong {
  display: block;
  margin-top: 3px;
  font-size: 1.12rem;
}

.manager-quote {
  padding: 10px 12px;
  border-left: 3px solid var(--amber);
  font-style: italic;
  color: var(--muted);
  font-size: 0.85rem;
}

/* ── Goal flash on scoreboard ───────────────────────────────── */

.score.flashing {
  animation: goalFlash 0.6s ease-out;
}

/* ── Suspended / injured player labels ──────────────────────── */

.suspended-label,
.injury-label {
  display: inline-flex;
  align-items: center;
  gap: 5px;
}

.suspended-label {
  color: var(--danger);
}

.injury-label {
  color: var(--amber);
}

.status-icon.injury-icon {
  flex: none;
}

.status-icon.suspended-icon {
  font-size: 0.85em;
  line-height: 1;
}

/* ── Main navigation tabs ────────────────────────────────────── */

.main-tabs {
  display: flex;
  gap: 8px;
  margin: 0 0 18px;
}

.tab-button {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 46px;
  padding: 0 20px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--panel);
  color: var(--muted);
  font-weight: 800;
  transition: color 140ms ease, border-color 140ms ease, background 140ms ease;
}

.tab-button:hover:not(:disabled) {
  color: var(--text);
}

.tab-button.active {
  color: var(--text);
  border-color: var(--accent);
  background: color-mix(in srgb, var(--accent) 16%, var(--panel));
  box-shadow: inset 0 -3px 0 var(--accent);
}

.tab-lock {
  font-size: 0.72rem;
  font-weight: 900;
  text-transform: uppercase;
  color: var(--danger);
  letter-spacing: 0.04em;
}

/* ── Setup / complete grids ──────────────────────────────────── */

.setup-grid {
  grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
}

.complete-grid {
  grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
}

.formation-panel {
  display: flex;
  flex-direction: column;
}

.complete-actions {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.complete-actions .primary-button,
.complete-actions .secondary-button {
  flex: 1;
  min-width: 160px;
}

/* ── Leaderboards screen ─────────────────────────────────────── */

.leaderboards-screen {
  display: grid;
  justify-items: center;
}

.leaderboards-panel {
  width: min(820px, 100%);
}

.segmented-lg {
  margin-bottom: 16px;
}

.segmented-lg button {
  min-height: 46px;
  font-size: 0.95rem;
}

.your-rank-card {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 14px;
  padding: 14px 16px;
  margin-bottom: 16px;
  border-radius: 10px;
  border: 1px solid var(--accent);
  background: color-mix(in srgb, var(--accent) 14%, var(--panel-strong));
}

.your-rank-badge {
  display: grid;
  place-items: center;
  min-width: 56px;
  height: 56px;
  padding: 0 10px;
  border-radius: 10px;
  background: var(--accent);
  color: #06110b;
  font-size: 1.35rem;
  font-weight: 900;
}

.your-rank-meta span {
  display: block;
  font-size: 0.72rem;
  font-weight: 900;
  text-transform: uppercase;
  color: var(--accent);
}

.your-rank-meta strong {
  font-size: 1.1rem;
}

.your-rank-stats {
  display: flex;
  gap: 16px;
}

.your-rank-stats div {
  text-align: center;
}

.your-rank-stats span {
  display: block;
  font-size: 0.68rem;
  color: var(--muted);
  text-transform: uppercase;
  font-weight: 800;
}

.your-rank-stats strong {
  font-size: 1.05rem;
}

.leaderboard-table {
  gap: 4px;
}

.lb-row {
  display: grid;
  grid-template-columns: 44px minmax(0, 1fr) 52px 52px 52px;
  gap: 8px;
  align-items: center;
  min-height: 44px;
  padding: 8px 12px;
  background: var(--panel-strong);
  border-radius: 8px;
  border: 1px solid transparent;
}

.lb-row strong {
  display: flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.lb-row > span:not(.lb-rank):not(.you-tag) {
  text-align: center;
  font-variant-numeric: tabular-nums;
}

.lb-rank {
  font-weight: 900;
  text-align: center;
  color: var(--muted);
}

.lb-head {
  background: transparent;
  font-size: 0.74rem;
  font-weight: 900;
  text-transform: uppercase;
  color: var(--muted);
  min-height: 30px;
}

.lb-head span { text-align: center; }
.lb-head span:nth-child(2) { text-align: left; }

.lb-row.podium { background: color-mix(in srgb, var(--amber) 8%, var(--panel-strong)); }
.lb-row.podium .lb-rank { font-size: 1.05rem; }
.lb-row.p1 { border-color: color-mix(in srgb, var(--amber) 60%, transparent); }

.lb-row.is-you {
  border-color: var(--accent);
  background: color-mix(in srgb, var(--accent) 16%, var(--panel-strong));
}

.you-tag {
  flex: none;
  padding: 1px 6px;
  border-radius: 4px;
  font-size: 0.62rem;
  font-weight: 900;
  letter-spacing: 0.05em;
  background: var(--accent);
  color: #06110b;
}

.lb-gap {
  text-align: center;
  color: var(--muted);
  font-weight: 900;
  letter-spacing: 0.2em;
  padding: 2px 0;
}

.leaderboard-empty {
  padding: 28px 12px;
  text-align: center;
}

/* ── Manager avatar ──────────────────────────────────────────── */

.assistant-strip {
  margin: 0 0 18px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background:
    linear-gradient(90deg, color-mix(in srgb, var(--accent) 10%, transparent), transparent 42%),
    var(--panel);
  box-shadow: var(--shadow);
}

.manager-avatar {
  display: flex;
  align-items: flex-end;
  gap: 10px;
  margin-top: 14px;
  padding-top: 14px;
  border-top: 1px dashed var(--line);
}

.manager-avatar.compact {
  align-items: center;
  margin: 0;
  padding: 10px 14px;
  border-top: 0;
}

.manager-avatar.compact svg {
  width: 54px;
  height: 66px;
}

.manager-figure {
  flex: none;
  line-height: 0;
  transform-origin: 50% 100%;
  animation: managerBob 3.6s ease-in-out infinite;
}

@keyframes managerBob {
  0%, 100% { transform: translateY(0) scaleY(1); }
  50% { transform: translateY(-2px) scaleY(1.015); }
}

.manager-shadow {
  transform-box: fill-box;
  transform-origin: center;
  animation: managerShadow 3.6s ease-in-out infinite;
}

@keyframes managerShadow {
  0%, 100% { transform: scale(1); opacity: 0.24; }
  50% { transform: scale(0.94); opacity: 0.18; }
}

.manager-eyes {
  transform-box: fill-box;
  transform-origin: center;
  animation: managerBlink 5.5s ease-in-out infinite;
}

@keyframes managerBlink {
  0%, 92%, 100% { transform: scaleY(1); }
  96% { transform: scaleY(0.1); }
}

.manager-arm { transform-box: fill-box; transform-origin: 4px 0px; }

.manager-arm-ready .manager-arm { animation: armReady 4.6s ease-in-out infinite; }
.manager-arm-think .manager-arm { animation: armThink 3.4s ease-in-out infinite; }
.manager-arm-happy .manager-arm { animation: armHappy 1.5s ease-in-out infinite; }
.manager-arm-sad .manager-arm { animation: armSad 5s ease-in-out infinite; }

@keyframes armReady {
  0%, 75%, 100% { transform: rotate(0deg); }
  85%, 92% { transform: rotate(-9deg); }
}

@keyframes armThink {
  0%, 100% { transform: rotate(-4deg); }
  50% { transform: rotate(-24deg); }
}

@keyframes armHappy {
  0%, 100% { transform: rotate(-15deg); }
  30% { transform: rotate(-112deg); }
  45% { transform: rotate(-96deg); }
  60% { transform: rotate(-106deg); }
}

@keyframes armSad {
  0%, 100% { transform: rotate(6deg); }
  50% { transform: rotate(16deg); }
}

.manager-figure.manager-arm-sad {
  animation: managerSlump 4.2s ease-in-out infinite;
}

@keyframes managerSlump {
  0%, 100% { transform: translateY(1px) scaleY(0.985); }
  50% { transform: translateY(3.5px) scaleY(0.97); }
}

.manager-speech {
  position: relative;
  flex: 1;
  padding: 10px 14px;
  background: var(--panel-strong);
  border: 1px solid var(--line);
  border-radius: 10px;
}

.manager-speech::before {
  content: "";
  position: absolute;
  left: -7px;
  bottom: 14px;
  width: 12px;
  height: 12px;
  background: var(--panel-strong);
  border-left: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
  transform: rotate(45deg);
}

.manager-speech p {
  margin: 0;
  color: var(--text);
  font-style: italic;
  font-size: 0.9rem;
  line-height: 1.45;
}

@media (prefers-reduced-motion: reduce) {
  .manager-figure,
  .manager-shadow,
  .manager-eyes,
  .manager-arm { animation: none !important; }
}

/* ── Upgraded pitch tokens ───────────────────────────────────── */

.pitch-container {
  background: #14361f;
}

.pitch-turf {
  position: absolute;
  inset: 0;
  background:
    repeating-linear-gradient(
      0deg,
      rgba(255, 255, 255, 0.05) 0,
      rgba(255, 255, 255, 0.05) 12.5%,
      rgba(0, 0, 0, 0.05) 12.5%,
      rgba(0, 0, 0, 0.05) 25%
    ),
    radial-gradient(120% 60% at 50% 0%, rgba(255, 255, 255, 0.12), transparent 60%),
    linear-gradient(180deg, #1c4a2c 0%, #225b34 50%, #1c4a2c 100%);
  pointer-events: none;
}

.pitch-token {
  position: relative;
  display: grid;
  place-items: center;
  color: var(--accent);
  filter: drop-shadow(0 3px 4px rgba(0, 0, 0, 0.5));
  transition: transform 140ms ease;
}

.pitch-player:hover .pitch-token {
  transform: scale(1.12);
}

.kit-icon {
  color: inherit;
}

.kit-num {
  position: absolute;
  top: 52%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 0.62rem;
  font-weight: 900;
  color: #06110b;
}

.pitch-token.injured { color: var(--danger); }
.pitch-token.injured .kit-num { color: #fff; }
.pitch-token.suspended { color: #ff7a2f; }
.pitch-token.suspended .kit-num { color: #fff; }

.pitch-token.ghost {
  color: rgba(255, 255, 255, 0.18);
  filter: none;
}

.pitch-player-ghost {
  animation: ghostPulse 2.6s ease-in-out infinite;
}

.pitch-player-ghost .pitch-pos {
  color: rgba(255, 255, 255, 0.32);
  background: rgba(0, 0, 0, 0.22);
}

@keyframes ghostPulse {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

.token-flag {
  position: absolute;
  top: -4px;
  right: -6px;
  display: grid;
  place-items: center;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  font-size: 0.6rem;
  font-weight: 900;
  color: #fff;
}

.token-flag.injury { background: var(--danger); }
.token-flag.susp { background: #ff4500; }
.token-flag.boost {
  left: -6px;
  right: auto;
  background: var(--amber);
  color: #1a1200;
}

.pitch-pos {
  margin-top: 1px;
  padding: 0 4px;
  font-size: 0.54rem;
  font-weight: 900;
  letter-spacing: 0.04em;
  color: var(--accent-strong);
  background: rgba(0, 0, 0, 0.4);
  border-radius: 3px;
  text-transform: uppercase;
}

.bench-row {
  align-items: center;
}

.bench-label {
  font-size: 0.7rem;
  font-weight: 900;
  text-transform: uppercase;
  color: var(--muted);
  margin-right: 2px;
}

.bench-player {
  border: 1px solid var(--line);
}

.bench-player small {
  color: var(--muted);
  font-size: 0.62rem;
  font-weight: 900;
}

.bench-player.out {
  border-color: var(--danger);
  opacity: 0.7;
}

.bench-num {
  display: grid;
  place-items: center;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: var(--amber);
  color: #1a1200;
  font-size: 0.6rem;
  font-weight: 900;
}

.bench-boost {
  display: grid;
  place-items: center;
  width: 17px;
  height: 17px;
  border-radius: 50%;
  background: var(--amber);
  color: #1a1200;
  font-size: 0.56rem;
  font-weight: 950;
}

/* ── Match-day atmosphere (league phase only) ────────────────── */

.matchday {
  position: relative;
  padding: 16px;
  border-radius: 12px;
  background:
    repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.025) 0 1px, transparent 1px 22px),
    linear-gradient(180deg, color-mix(in srgb, var(--accent) 6%, var(--bg)) 0%, var(--bg) 30%);
  overflow: hidden;
}

.matchday::before {
  content: "";
  position: absolute;
  inset: 0 0 auto 0;
  height: 70px;
  background:
    repeating-linear-gradient(90deg, rgba(255,255,255,0.05) 0 3px, transparent 3px 9px),
    repeating-linear-gradient(90deg, var(--panel-strong) 0 7px, var(--panel) 7px 14px);
  opacity: 0.55;
  -webkit-mask-image: linear-gradient(180deg, #000 0%, transparent 100%);
  mask-image: linear-gradient(180deg, #000 0%, transparent 100%);
  pointer-events: none;
}

.matchday::after {
  content: "";
  position: absolute;
  top: -40px;
  left: 50%;
  width: 300px;
  height: 120px;
  transform: translateX(-50%);
  background: linear-gradient(180deg, rgba(255, 255, 240, 0.13), transparent);
  pointer-events: none;
  animation: floodlight 6s ease-in-out infinite;
}

@keyframes floodlight {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 0.85; }
}

.matchday > .panel,
.matchday > .side-stack {
  position: relative;
  z-index: 1;
}

/* Clean sportsbook-style refresh */
.app-shell {
  width: min(1180px, 100%);
  padding: 14px 18px;
}

.topbar {
  padding: 10px 16px;
  background: linear-gradient(90deg, #2f4f8f, #4267b2);
  border: 0;
  border-radius: 8px;
  box-shadow: 0 10px 24px rgba(47, 79, 143, 0.18);
}

.topbar .eyebrow,
.topbar h1,
.topbar .profile-pill,
.topbar .icon-button {
  color: #ffffff;
}

.topbar .eyebrow {
  color: rgba(255, 255, 255, 0.78);
}

.topbar h1 {
  max-width: 650px;
  font-size: clamp(1.1rem, 2.1vw, 1.55rem);
}

.brand-mark {
  width: 44px;
  height: 44px;
  background: #ffffff;
  color: var(--accent);
  box-shadow: none;
}

.brand-logo {
  width: 34px;
  height: 34px;
}

.brand-logo-ball,
.brand-logo-trail {
  fill: var(--accent);
  stroke: var(--accent);
}

.brand-logo-seam {
  stroke: #ffffff;
}

.icon-button,
.profile-pill,
.secondary-button,
.formation-button,
.choice-card,
.player-card,
.segmented button,
.sub-row button {
  border-radius: 8px;
}

.topbar .icon-button,
.topbar .profile-pill,
.lang-btn {
  background: rgba(255, 255, 255, 0.12);
  border-color: rgba(255, 255, 255, 0.24);
}

.lang-btn.active,
.topbar .icon-button:hover:not(:disabled),
.topbar .profile-pill:hover:not(:disabled) {
  background: #ffffff;
  color: var(--accent);
  border-color: #ffffff;
}

.primary-button {
  min-height: 44px;
  background: var(--button);
  border-color: var(--button);
  border-radius: 8px;
  color: #ffffff;
  box-shadow: none;
}

.primary-button:hover:not(:disabled) {
  box-shadow: 0 8px 18px rgba(215, 25, 32, 0.18);
}

.secondary-button,
.profile-pill,
.icon-button {
  background: #ffffff;
  border-color: var(--line);
  color: var(--accent);
}

.secondary-button:hover:not(:disabled),
.formation-button:hover:not(:disabled),
.choice-card:hover:not(:disabled),
.tab-button:hover:not(:disabled) {
  border-color: var(--accent);
  box-shadow: none;
}

.icon-button:hover:not(:disabled),
.primary-button:hover:not(:disabled),
.secondary-button:hover:not(:disabled),
.formation-button:hover:not(:disabled),
.choice-card:hover:not(:disabled),
.player-card:hover:not(:disabled) {
  transform: none;
}

.status-strip {
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0;
  margin: 12px 0;
  overflow: hidden;
  background: #ffffff;
  border: 1px solid var(--line);
  border-radius: 8px;
  box-shadow: var(--shadow);
}

.status-strip div {
  min-height: 52px;
  padding: 9px 14px;
  background: transparent;
  border: 0;
  border-right: 1px solid var(--line);
  border-radius: 0;
  box-shadow: none;
}

.status-strip div:last-child {
  border-right: 0;
}

.status-strip span {
  color: var(--muted);
  font-size: 0.78rem;
  font-weight: 700;
}

.status-strip strong {
  color: var(--text);
  font-size: 0.98rem;
}

.main-tabs {
  gap: 8px;
  margin-bottom: 14px;
}

.tab-button {
  min-height: 40px;
  background: #ffffff;
  border-color: var(--line);
  color: var(--accent);
  box-shadow: none;
}

.tab-button.active {
  background: var(--accent);
  border-color: var(--accent);
  color: #ffffff;
  box-shadow: none;
}

.assistant-strip {
  display: none;
}

.manager-avatar.compact .manager-figure {
  display: none;
}

.manager-avatar.compact {
  padding: 12px 14px;
}

.manager-speech {
  padding: 0;
  background: transparent;
  border: 0;
}

.manager-speech::before {
  display: none;
}

.manager-speech p {
  color: var(--text);
  font-size: 0.9rem;
  font-style: normal;
}

.layout-grid,
.draft-layout,
.league-layout {
  gap: 14px;
}

.panel {
  padding: 18px;
  background: #ffffff;
  border: 1px solid var(--line);
  border-radius: 8px;
  box-shadow: var(--shadow);
}

.panel::before,
.fm-card::before {
  display: none;
}

.intro-panel {
  min-height: 0;
  justify-content: flex-start;
}

.eyebrow {
  color: var(--accent);
  font-size: 0.72rem;
  letter-spacing: 0.02em;
}

h2 {
  margin-bottom: 8px;
  color: var(--text);
  font-size: 1.35rem;
}

p {
  color: var(--muted);
}

.manager-pick,
.progression-panel,
.score-change-card,
.prematch-panel,
.season-event-card,
.draw-ticket,
.fit-explainer,
.slot-picker,
.hidden-stats,
.commentary-log,
.injury-prompt {
  background: var(--panel-strong);
  border: 1px solid var(--line);
  border-radius: 8px;
  box-shadow: none;
}

.mode-grid {
  gap: 10px;
  margin: 12px 0;
}

.choice-card,
.formation-button,
.player-card,
.slot-option {
  background: #ffffff;
  border: 1px solid var(--line);
  color: var(--text);
  box-shadow: none;
}

.choice-card.active,
.formation-button.active,
.segmented .active {
  background: #e8f2ff;
  border-color: var(--accent);
  color: var(--text);
}

.choice-card strong,
.formation-button span {
  color: var(--text);
}

.choice-card small {
  margin-top: 6px;
  color: var(--muted);
  line-height: 1.35;
}

.formation-grid {
  gap: 10px;
}

.formation-button {
  min-height: 58px;
  padding: 10px 14px;
}

.formation-glyph-pitch {
  fill: #e8f2ff;
  stroke: var(--line);
}

.formation-glyph-stroke {
  stroke: #a7b7c9;
}

.formation-glyph-dot,
.formation-button.active .formation-glyph-dot {
  fill: var(--accent);
}

.manager-pick {
  gap: 8px;
  margin: 10px 0;
  padding: 12px;
  background: #f8fbff;
  border-radius: 8px;
}

.manager-pick .spin-bank {
  width: auto;
  flex: 1;
}

.manager-pick-prompt {
  margin-bottom: 4px;
}

.manager-pick-head {
  gap: 12px;
}

.manager-pick-name {
  display: block;
  margin-top: 2px;
}

.manager-pick-club {
  display: block;
  margin-top: 4px;
}

.manager-pick-actions {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.manager-pick-actions .primary-button,
.manager-pick-actions .secondary-button {
  flex: none;
}

.intro-panel > .primary-button {
  margin-top: 4px;
}

.spin-bank {
  background: #e8f2ff;
  border-color: #c9ddf5;
  color: var(--accent);
}

.progression-panel,
.score-change-card {
  margin: 14px 0;
}

.progression-level-chip,
.rating-chip,
.card-ovr,
.you-tag,
.lb-row.is-you .you-tag {
  background: var(--accent);
  color: #ffffff;
}

.progress-track {
  background: #dfe8f2;
}

.progress-track span,
.ovr-bar-fill {
  background: var(--accent);
}

.draft-board {
  min-height: 0;
}

.empty-state {
  min-height: 300px;
}

.empty-state-card {
  background: #ffffff;
  border-color: var(--line);
}

.draw-ticket {
  border-style: solid;
}

.fm-card {
  background: #ffffff;
}

.card-pos,
.role-targets,
.boost-cap {
  color: var(--accent);
}

.card-ovr.hidden {
  background: var(--panel-strong);
  color: var(--muted);
}

.stat-row span {
  background: var(--panel-strong);
}

.scoreboard {
  background: var(--accent);
  color: #ffffff;
}

.scoreboard span {
  color: rgba(255, 255, 255, 0.78);
}

.scoreboard strong,
.score {
  color: #ffffff;
}

.score {
  font-size: 1.85rem;
}

.timer {
  background: #e8f2ff;
  color: var(--accent);
}

.commentary-log {
  background: #f7fafd;
}

:root[data-theme="light"] .commentary-log {
  background: #f7fafd;
}

.commentary-line {
  background: #ffffff;
  border: 1px solid #edf2f7;
}

.table-row,
.squad-row,
.injury-row,
.summary-row,
.season-result-row,
.lb-row,
.bench-player,
.season-stat-grid div,
.your-rank-card {
  background: var(--panel-strong);
  border: 1px solid #edf2f7;
}

.table-row {
  border-radius: 8px;
}

.lb-row.podium,
.lb-row.is-you {
  background: #e8f2ff;
  border-color: #c9ddf5;
}

.matchday {
  padding: 0;
  background: transparent;
  overflow: visible;
}

.matchday::before,
.matchday::after {
  display: none;
}

.pitch-container {
  background: #0f7a4a;
}

.pitch-token,
.player-shirt {
  color: #ffffff;
}

.kit-num,
.player-shirt span {
  color: var(--accent);
}

.pitch-name {
  color: #ffffff;
}

/* Smooth setup composition */
.status-strip {
  gap: 8px;
  padding: 8px;
  background: rgba(255, 255, 255, 0.72);
  border: 0;
  box-shadow: none;
}

.status-strip div {
  min-height: 46px;
  padding: 7px 10px;
  border-right: 0;
  border-radius: 8px;
}

.main-tabs {
  width: fit-content;
  padding: 3px;
  background: rgba(255, 255, 255, 0.78);
  border-radius: 8px;
}

.tab-button {
  border-color: transparent;
  background: transparent;
}

.tab-button.active {
  border-color: transparent;
}

.setup-grid {
  grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
  gap: 22px;
  align-items: start;
  padding: 18px;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 8px;
  box-shadow: 0 18px 38px rgba(13, 49, 91, 0.08);
}

.setup-grid > .panel {
  padding: 0;
  background: transparent;
  border: 0;
  box-shadow: none;
}

.setup-grid .mode-grid {
  gap: 6px;
  padding: 4px;
  background: #f4f8fd;
  border-radius: 8px;
}

.setup-grid .choice-card,
.setup-grid .formation-button {
  border-color: transparent;
  background: #f4f8fd;
}

.setup-grid .choice-card.active,
.setup-grid .formation-button.active {
  background: #ffffff;
  border-color: transparent;
  box-shadow:
    inset 0 0 0 1px var(--accent),
    0 8px 18px rgba(0, 87, 184, 0.08);
}

.setup-grid .choice-card:hover:not(:disabled),
.setup-grid .formation-button:hover:not(:disabled) {
  background: #ffffff;
}

.setup-grid .manager-pick,
.setup-grid .progression-panel {
  border: 0;
  background: #f4f8fd;
}

.setup-grid .manager-pick {
  margin: 12px 0;
  padding: 14px;
}

.setup-grid .spin-bank {
  border-color: transparent;
  background: #e8f2ff;
}

.setup-grid .formation-grid {
  gap: 8px;
}

.setup-grid .formation-button {
  min-height: 58px;
}

.setup-grid .formation-glyph-pitch {
  fill: #e8f2ff;
  stroke: transparent;
}

.setup-grid .formation-glyph-stroke {
  stroke: #bfd3ea;
}

.setup-grid .formation-panel {
  gap: 14px;
}

.formation-preview {
  display: grid;
  gap: 12px;
  margin-top: 2px;
  padding: 12px;
  background: #f4f8fd;
  border-radius: 8px;
}

.formation-preview-head,
.formation-preview-meta {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
}

.formation-preview-head div,
.formation-preview-meta span {
  min-width: 0;
  padding: 10px 12px;
  border-radius: 8px;
  background: #ffffff;
}

.formation-preview-head span,
.formation-preview-meta span {
  color: var(--muted);
  font-size: 0.72rem;
  font-weight: 800;
}

.formation-preview-head strong,
.formation-preview-meta strong {
  display: block;
  margin-top: 3px;
  color: var(--text);
  font-size: 0.98rem;
}

.formation-preview-pitch {
  position: relative;
  min-height: 278px;
  overflow: hidden;
  border-radius: 8px;
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.035) 50%, transparent 50%) 0 0 / 64px 100%,
    linear-gradient(180deg, #254f85, #203f6f);
}

.formation-preview-pitch::before {
  content: "";
  position: absolute;
  inset: 12px;
  border: 1px solid rgba(255, 255, 255, 0.36);
  border-radius: 7px;
}

.formation-preview-line {
  position: absolute;
  left: 12px;
  right: 12px;
  height: 1px;
  background: rgba(255, 255, 255, 0.32);
}

.formation-preview-line.halfway {
  top: 50%;
}

.formation-preview-circle {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 66px;
  height: 66px;
  border: 1px solid rgba(255, 255, 255, 0.32);
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.formation-preview-dot {
  position: absolute;
  display: grid;
  place-items: center;
  min-width: 34px;
  height: 28px;
  padding: 0 7px;
  border-radius: 999px;
  background: #ffffff;
  color: #2f4f8f;
  font-size: 0.66rem;
  font-weight: 950;
  line-height: 1;
  box-shadow: 0 7px 14px rgba(6, 31, 61, 0.18);
  transform: translate(-50%, -50%);
}

.formation-preview-meta {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.formation-preview-meta span {
  text-align: center;
}

.personal-screen {
  display: grid;
  justify-items: center;
}

.personal-panel {
  width: min(980px, 100%);
}

.personal-hero {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  margin-bottom: 14px;
}

.personal-hero > div,
.personal-stat-grid > div,
.personal-card,
.personal-best-grid > div,
.period-rank-row,
.recent-run-row {
  background: #f4f8fd;
  border-radius: 8px;
}

.personal-hero > div {
  padding: 16px;
}

.personal-hero span,
.personal-stat-grid span,
.personal-best-grid span,
.period-rank-row span,
.recent-run-row small {
  color: var(--muted);
  font-size: 0.72rem;
  font-weight: 800;
  text-transform: uppercase;
}

.personal-hero strong {
  display: block;
  margin: 4px 0 6px;
  color: var(--text);
  font-size: 2rem;
  line-height: 1;
}

.personal-hero p {
  margin: 0;
}

.personal-stat-grid {
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  gap: 8px;
  margin-bottom: 14px;
}

.personal-stat-grid > div {
  padding: 12px;
}

.personal-stat-grid strong,
.personal-best-grid strong,
.period-rank-row strong,
.recent-run-row strong {
  display: block;
  margin-top: 3px;
  color: var(--text);
  font-size: 1.05rem;
}

.personal-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
  gap: 14px;
  margin-bottom: 14px;
}

.personal-card {
  padding: 14px;
}

.personal-best-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
}

.personal-best-grid > div {
  padding: 12px;
  background: #ffffff;
}

.personal-best-grid small,
.period-rank-row small {
  display: block;
  margin-top: 3px;
  color: var(--muted);
  font-size: 0.78rem;
  font-weight: 700;
}

.period-rank-grid,
.recent-run-list {
  display: grid;
  gap: 8px;
}

.period-rank-row {
  display: grid;
  grid-template-columns: 76px 56px 1fr;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  background: #ffffff;
}

.period-rank-row span {
  text-transform: capitalize;
}

.period-rank-row strong {
  margin: 0;
  color: var(--accent);
}

.recent-run-row {
  display: grid;
  grid-template-columns: 90px repeat(3, minmax(56px, 1fr)) 80px;
  align-items: center;
  gap: 8px;
  padding: 10px 12px;
}

.recent-run-row span {
  color: var(--text);
  font-size: 0.88rem;
  font-weight: 800;
}

.recent-run-row small {
  text-align: right;
}

.personal-empty {
  margin: 0;
  padding: 16px;
  border-radius: 8px;
  background: #ffffff;
}

@media (prefers-reduced-motion: reduce) {
  .matchday::after { animation: none; }
}

@media (max-width: 1120px) {
  .layout-grid,
  .draft-layout,
  .league-layout,
  .setup-grid,
  .complete-grid,
  .personal-grid {
    grid-template-columns: 1fr;
  }

  .personal-stat-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

@media (max-width: 720px) {
  .main-tabs .tab-button {
    flex: 1;
    padding: 0 10px;
  }

  .your-rank-card {
    grid-template-columns: auto 1fr;
  }

  .your-rank-stats {
    grid-column: 1 / -1;
    justify-content: space-around;
  }

  .lb-row {
    grid-template-columns: 32px minmax(0, 1fr) 40px 40px 40px;
    padding: 8px;
    gap: 4px;
  }
}

@media (max-width: 720px) {
  .app-shell {
    padding: 12px;
  }

  .topbar,
  .brand-lockup,
  .topbar-actions,
  .panel-header,
  .email-form {
    align-items: stretch;
    flex-direction: column;
  }

  .status-strip,
  .mode-grid,
  .formation-grid,
  .scoreboard,
  .slot-picker {
    grid-template-columns: 1fr;
  }

  .candidate-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .slot-option-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .draft-spin-controls,
  .match-actions {
    justify-content: stretch;
  }

  .draft-spin-controls > *,
  .match-actions > .primary-button,
  .match-actions > .secondary-button {
    width: 100%;
  }

  .scoreboard > div:last-child {
    text-align: left;
  }

  .squad-row {
    grid-template-columns: 1fr;
  }

  .table-row {
    grid-template-columns: minmax(0, 1fr) 34px 34px 34px;
    gap: 4px;
    padding: 8px;
    font-size: 0.92rem;
  }

  .commentary-log {
    max-height: 300px;
  }
}

@media (max-width: 720px) {
  .topbar {
    flex-direction: column;
    align-items: stretch;
    padding: 12px;
  }

  .brand-lockup {
    flex: none;
    width: 100%;
    flex-direction: row;
    align-items: center;
  }

  .topbar h1 {
    font-size: 1.08rem;
    line-height: 1.12;
  }

  .topbar-actions {
    flex: none;
    width: 100%;
    flex-direction: row;
    align-items: center;
    gap: 6px;
  }

  .lang-switcher {
    display: flex;
    gap: 5px;
  }

  .lang-btn {
    min-width: 34px;
    min-height: 34px;
    padding: 0 8px;
  }

  .topbar .icon-button,
  .topbar .profile-pill {
    min-height: 36px;
    height: 36px;
  }

  .topbar .icon-button {
    width: 38px;
  }

  .topbar .profile-pill {
    flex: 1;
    padding: 0 10px;
  }

  .status-strip {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .status-strip div {
    min-height: 54px;
    border-right: 0;
    border-bottom: 1px solid var(--line);
  }

  .status-strip div:nth-child(odd) {
    border-right: 1px solid var(--line);
  }

  .status-strip div:nth-last-child(-n + 2) {
    border-bottom: 0;
  }

  .main-tabs {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    width: 100%;
  }

  .mode-grid {
    grid-template-columns: 1fr;
  }

  .personal-hero,
  .personal-best-grid {
    grid-template-columns: 1fr;
  }

  .personal-stat-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .period-rank-row,
  .recent-run-row {
    grid-template-columns: 1fr;
  }

  .recent-run-row small {
    text-align: left;
  }
}
